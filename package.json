{
  "name": "m365-migration-platform",
  "version": "0.1.0",
  "private": true,
  "description": "M365 tenant-to-tenant migration platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @m365-migration/database generate",
    "db:push": "pnpm --filter @m365-migration/database db:push",
    "db:migrate": "pnpm --filter @m365-migration/database db:migrate",
    "db:studio": "pnpm --filter @m365-migration/database studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
