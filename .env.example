# ============================================
# M365 Migration Platform — Environment Config
# ============================================

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/m365_migration

# Redis (Azure Cache for Redis uses port 6380 with TLS)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT Authentication (REQUIRED in production)
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption Key (REQUIRED in production — exactly 32 characters)
# Used to encrypt tenant client secrets at rest
ENCRYPTION_KEY=change-this-to-32-char-key-prod!

# API Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (optional — falls back to console logging if not set)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@m365migrate.com

# Stripe Billing (optional for Stage 1, required for SaaS)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FREE=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_ADDON_ONEDRIVE=
STRIPE_PRICE_ADDON_SHAREPOINT=
STRIPE_PRICE_ADDON_TEAMS=
STRIPE_PRICE_ADDON_GROUPS=
STRIPE_PRICE_ADDON_PLANNER=
STRIPE_PRICE_ADDON_ENTRA_ID=

# Azure AD App Registration (optional — for future OAuth login)
# Not needed for Stage 1; tenant creds are provided via API at runtime
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# Azure Storage (for large file migration staging — optional)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=migration-staging

# Worker Health Server
HEALTH_PORT=8080
