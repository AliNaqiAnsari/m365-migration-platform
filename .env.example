# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/m365_migration

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Azure AD App Registration (multi-tenant app for M365 access)
# Create at: https://portal.azure.com → App registrations → New registration
# Required permissions:
#   - User.Read.All, Group.ReadWrite.All, Mail.ReadWrite
#   - Sites.ReadWrite.All, Files.ReadWrite.All
#   - TeamSettings.ReadWrite.All, ChannelMessage.Read.All, Teamwork.Migrate.All
#   - Tasks.ReadWrite.All, Directory.ReadWrite.All
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common

# Encryption (32 characters exactly)
ENCRYPTION_KEY=change-this-to-32-char-key-prod!

# API
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Azure Storage (for SharePoint migration staging)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=migration-staging
