generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Organization & Auth (multi-tenant SaaS)
// ============================================================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  billingEmail String? @map("billing_email")
  stripeCustomerId String? @unique @map("stripe_customer_id")
  plan        OrgPlan  @default(FREE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users        User[]
  tenants      Tenant[]
  migrationJobs MigrationJob[]
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]
  subscription Subscription?
  usageRecords UsageRecord[]
  invitations  Invitation[]
  webhookEndpoints WebhookEndpoint[]

  @@map("organizations")
}

enum OrgPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id             String   @id @default(uuid())
  email          String
  passwordHash   String?  @map("password_hash")
  name           String
  role           UserRole @default(MEMBER)
  authProvider   AuthProvider @default(LOCAL) @map("auth_provider")
  authProviderId String?  @map("auth_provider_id")
  mfaEnabled     Boolean  @default(false) @map("mfa_enabled")
  mfaSecret      String?  @map("mfa_secret")
  avatarUrl      String?  @map("avatar_url")
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  organizationId String   @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions       Session[]

  @@unique([email, organizationId])
  @@index([organizationId])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuthProvider {
  LOCAL
  MICROSOFT
  GOOGLE
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model ApiKey {
  id             String   @id @default(uuid())
  name           String
  keyHash        String   @unique @map("key_hash")
  keyPrefix      String   @map("key_prefix")
  organizationId String   @map("organization_id")
  createdBy      String   @map("created_by")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

// ============================================================
// Tenant Connections (M365 / Google Workspace)
// ============================================================

model Tenant {
  id               String       @id @default(uuid())
  organizationId   String       @map("organization_id")
  name             String
  tenantId         String       @map("tenant_id") // Azure AD tenant ID
  domain           String       // Primary domain
  provider         TenantProvider @default(MICROSOFT_365)
  connectionType   ConnectionType
  status           TenantStatus @default(PENDING)

  // Encrypted OAuth tokens (encrypted at application level)
  accessToken      String?      @map("access_token")
  refreshToken     String?      @map("refresh_token")
  tokenExpiresAt   DateTime?    @map("token_expires_at")

  // App registration details
  clientId         String?      @map("client_id")
  clientSecret     String?      @map("client_secret") // encrypted

  // Metadata
  userCount        Int?         @map("user_count")
  storageUsedBytes BigInt?      @map("storage_used_bytes")
  lastSyncAt       DateTime?    @map("last_sync_at")
  metadata         Json         @default("{}")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  discoveries      TenantDiscovery[]
  sourceMigrations MigrationJob[] @relation("SourceTenant")
  destMigrations   MigrationJob[] @relation("DestinationTenant")

  @@unique([organizationId, tenantId, connectionType])
  @@index([organizationId])
  @@map("tenants")
}

enum TenantProvider {
  MICROSOFT_365
  GOOGLE_WORKSPACE
}

enum ConnectionType {
  SOURCE
  DESTINATION
}

enum TenantStatus {
  PENDING
  CONNECTED
  ERROR
  DISCONNECTED
}

// ============================================================
// Tenant Discovery (inventory cache)
// ============================================================

model TenantDiscovery {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  jobId         String?  @map("job_id")
  objectType    DiscoveryObjectType @map("object_type")
  objectId      String   @map("object_id")
  displayName   String   @map("display_name")
  identifier    String?  // UPN, email, URL, etc.
  sizeBytes     BigInt   @default(0) @map("size_bytes")
  itemCount     Int      @default(0) @map("item_count")
  properties    Json     @default("{}")
  discoveredAt  DateTime @default(now()) @map("discovered_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  job           MigrationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([tenantId, objectType, objectId])
  @@index([tenantId, objectType])
  @@index([jobId])
  @@map("tenant_discoveries")
}

enum DiscoveryObjectType {
  USER
  GROUP
  SECURITY_GROUP
  DISTRIBUTION_LIST
  SHARED_MAILBOX
  ROOM_MAILBOX
  SITE
  TEAM
  CHANNEL
  DRIVE
  PLAN
  LICENSE_SKU
}

// ============================================================
// Migration Jobs & Tasks
// ============================================================

model MigrationJob {
  id               String          @id @default(uuid())
  organizationId   String          @map("organization_id")
  sourceTenantId   String          @map("source_tenant_id")
  destTenantId     String          @map("dest_tenant_id")
  name             String
  description      String?
  jobType          MigrationJobType @default(FULL) @map("job_type")
  status           MigrationJobStatus @default(CREATED)
  currentPhase     MigrationPhase  @default(CREATED) @map("current_phase")

  // Workloads to migrate
  workloads        Workload[]

  // Configuration
  options          Json            @default("{}") // concurrent tasks, batch size, etc.
  retryPolicy      Json            @default("{\"maxRetries\": 3, \"backoffMs\": 5000}") @map("retry_policy")

  // Progress
  totalItems       Int             @default(0) @map("total_items")
  processedItems   Int             @default(0) @map("processed_items")
  failedItems      Int             @default(0) @map("failed_items")
  skippedItems     Int             @default(0) @map("skipped_items")
  totalBytes       BigInt          @default(0) @map("total_bytes")
  processedBytes   BigInt          @default(0) @map("processed_bytes")

  // Timing
  startedAt        DateTime?       @map("started_at")
  completedAt      DateTime?       @map("completed_at")
  estimatedEndAt   DateTime?       @map("estimated_end_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sourceTenant     Tenant          @relation("SourceTenant", fields: [sourceTenantId], references: [id])
  destTenant       Tenant          @relation("DestinationTenant", fields: [destTenantId], references: [id])
  tasks            MigrationTask[]
  mappings         IdentityMapping[]
  deadLetterItems  DeadLetterItem[]
  discoveries      TenantDiscovery[]
  activityLogs     ActivityLog[]

  @@index([organizationId])
  @@index([status])
  @@index([organizationId, status])
  @@map("migration_jobs")
}

enum MigrationJobType {
  FULL
  INCREMENTAL
  SELECTIVE
  CUTOVER
  PILOT
}

enum MigrationJobStatus {
  CREATED
  DISCOVERING
  MAPPING
  READY
  IN_PROGRESS
  PAUSED
  CANCELLING
  CANCELLED
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum MigrationPhase {
  CREATED
  DISCOVERY
  MAPPING
  PRE_MIGRATION
  MIGRATION
  VALIDATION
  CUTOVER
  COMPLETED
}

enum Workload {
  EXCHANGE
  ONEDRIVE
  SHAREPOINT
  TEAMS
  GROUPS
  PLANNER
  ENTRA_ID
}

model MigrationTask {
  id              String           @id @default(uuid())
  jobId           String           @map("job_id")
  parentTaskId    String?          @map("parent_task_id")
  workload        Workload
  taskType        String           @map("task_type") // e.g., "mailbox", "site", "drive", "team"
  status          TaskStatus       @default(PENDING)
  priority        Int              @default(0)

  // What is being migrated
  sourceObjectId  String           @map("source_object_id")
  sourceObjectName String?         @map("source_object_name")
  destObjectId    String?          @map("dest_object_id")

  // Progress
  totalItems      Int              @default(0) @map("total_items")
  processedItems  Int              @default(0) @map("processed_items")
  failedItems     Int              @default(0) @map("failed_items")
  totalBytes      BigInt           @default(0) @map("total_bytes")
  processedBytes  BigInt           @default(0) @map("processed_bytes")
  progressPercent Float            @default(0) @map("progress_percent")

  // Retry
  retryCount      Int              @default(0) @map("retry_count")
  maxRetries      Int              @default(3) @map("max_retries")
  lastError       String?          @map("last_error")

  // Checkpoint
  checkpointData  Json?            @map("checkpoint_data")
  lastCheckpointAt DateTime?       @map("last_checkpoint_at")

  // Timing
  startedAt       DateTime?        @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  job             MigrationJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  parentTask      MigrationTask?   @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks        MigrationTask[]  @relation("SubTasks")
  errors          MigrationItemError[]

  @@index([jobId])
  @@index([jobId, workload])
  @@index([jobId, status])
  @@index([parentTaskId])
  @@map("migration_tasks")
}

enum TaskStatus {
  PENDING
  QUEUED
  IN_PROGRESS
  PAUSED
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  CANCELLED
  SKIPPED
}

model MigrationItemError {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  itemId      String?  @map("item_id")
  itemName    String?  @map("item_name")
  itemType    String?  @map("item_type")
  errorCode   String   @map("error_code")
  errorMessage String  @map("error_message")
  errorCategory ErrorCategory @default(PERMANENT) @map("error_category")
  httpStatus  Int?     @map("http_status")
  retryable   Boolean  @default(false)
  retried     Boolean  @default(false)
  retriedAt   DateTime? @map("retried_at")
  stackTrace  String?  @map("stack_trace")
  createdAt   DateTime @default(now()) @map("created_at")

  task        MigrationTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, errorCategory])
  @@map("migration_item_errors")
}

enum ErrorCategory {
  RATE_LIMITED
  TRANSIENT
  AUTH_EXPIRED
  PERMISSION_DENIED
  NOT_FOUND
  CONFLICT
  PAYLOAD_TOO_LARGE
  PERMANENT
}

// ============================================================
// Identity Mapping (source → destination)
// ============================================================

model IdentityMapping {
  id              String         @id @default(uuid())
  jobId           String         @map("job_id")
  objectType      DiscoveryObjectType @map("object_type")
  sourceId        String         @map("source_id")
  sourceIdentifier String?       @map("source_identifier") // UPN, email, URL
  destinationId   String?        @map("destination_id")
  destIdentifier  String?        @map("dest_identifier")
  status          MappingStatus  @default(PENDING)
  matchStrategy   MatchStrategy? @map("match_strategy")
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  job             MigrationJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, objectType, sourceId])
  @@index([jobId, objectType])
  @@index([sourceId])
  @@index([destinationId])
  @@index([jobId, status])
  @@map("identity_mappings")
}

enum MappingStatus {
  PENDING
  AUTO_MATCHED
  MANUALLY_MATCHED
  CREATED_IN_DEST
  SKIPPED
  FAILED
}

enum MatchStrategy {
  UPN_MATCH
  EMAIL_MATCH
  DISPLAY_NAME_MATCH
  URL_PATTERN_MATCH
  MANUAL
  AUTO_CREATED
}

// ============================================================
// Dead Letter Queue (persistent)
// ============================================================

model DeadLetterItem {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  taskId          String?  @map("task_id")
  workload        Workload
  itemId          String   @map("item_id")
  itemType        String   @map("item_type")
  itemName        String?  @map("item_name")
  errorCode       String   @map("error_code")
  errorMessage    String   @map("error_message")
  errorDetails    Json?    @map("error_details")
  originalPayload Json     @map("original_payload")
  retryCount      Int      @default(0) @map("retry_count")
  maxRetries      Int      @default(3) @map("max_retries")
  resolvedAt      DateTime? @map("resolved_at")
  resolution      String?  // "retried_success", "skipped", "manual_fix"
  createdAt       DateTime @default(now()) @map("created_at")

  job             MigrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, workload])
  @@map("dead_letter_items")
}

// ============================================================
// Activity Log
// ============================================================

model ActivityLog {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  jobId          String?      @map("job_id")
  userId         String?      @map("user_id")
  category       LogCategory
  action         String
  details        Json         @default("{}")
  ipAddress      String?      @map("ip_address")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job            MigrationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([jobId])
  @@index([organizationId, category])
  @@index([createdAt])
  @@map("activity_logs")
}

enum LogCategory {
  AUTH
  MIGRATION
  TENANT
  SYSTEM
  BILLING
}

// ============================================================
// Billing & Subscriptions
// ============================================================

model Subscription {
  id                    String             @id @default(uuid())
  organizationId        String             @unique @map("organization_id")
  stripeSubscriptionId  String?            @unique @map("stripe_subscription_id")
  stripePriceId         String?            @map("stripe_price_id")
  plan                  OrgPlan
  status                SubscriptionStatus @default(TRIALING)
  workloadAddons        Workload[]         @map("workload_addons")
  currentPeriodStart    DateTime?          @map("current_period_start")
  currentPeriodEnd      DateTime?          @map("current_period_end")
  cancelAtPeriodEnd     Boolean            @default(false) @map("cancel_at_period_end")
  trialEndsAt           DateTime?          @map("trial_ends_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

model UsageRecord {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  periodStart        DateTime @map("period_start")
  periodEnd          DateTime @map("period_end")
  dataMigratedBytes  BigInt   @default(0) @map("data_migrated_bytes")
  itemsMigrated      Int      @default(0) @map("items_migrated")
  apiCalls           Int      @default(0) @map("api_calls")
  createdAt          DateTime @default(now()) @map("created_at")

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodStart])
  @@index([organizationId])
  @@map("usage_records")
}

// ============================================================
// Invitations
// ============================================================

model Invitation {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  email           String
  role            UserRole  @default(MEMBER)
  token           String    @unique
  invitedBy       String    @map("invited_by")
  expiresAt       DateTime  @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("invitations")
}

// ============================================================
// Webhooks
// ============================================================

model WebhookEndpoint {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  url             String
  events          String[]
  secret          String
  isActive        Boolean  @default(true) @map("is_active")
  failCount       Int      @default(0) @map("fail_count")
  lastDeliveredAt DateTime? @map("last_delivered_at")
  createdAt       DateTime @default(now()) @map("created_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("webhook_endpoints")
}
